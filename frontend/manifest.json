{
    "manifest_version": 3,
    "name": "NERD",
    "version": "1.0.0",
    "description": "A browser extension.",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "run_at": "document_idle",
            "js": [
                "./src/scripts/LocalFormSaver.js"
            ]
        }
    ],
    "action": {
        "default_popup": "index.html"
    }
}