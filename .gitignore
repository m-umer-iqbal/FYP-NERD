# =============================================================
#   ROOT .gitignore  —  covers Backend + shared repo stuff
#   (Frontend has its own .gitignore generated by Vite)
# =============================================================


# ——————————————————————————————————————————
#  NODE MODULES  (both frontend & backend, just in case)
# ——————————————————————————————————————————
node_modules/
frontend/node_modules/
backend/node_modules/


# ——————————————————————————————————————————
#  ENVIRONMENT & SECRETS  ← never commit these
# ——————————————————————————————————————————
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

frontend/.env
frontend/.env.*
backend/.env
backend/.env.*


# ——————————————————————————————————————————
#  BUILD OUTPUTS
# ——————————————————————————————————————————

# React / Vite build
frontend/dist/
frontend/build/
frontend/.vite/

# Express / Backend build (if you add TypeScript or a bundler later)
backend/dist/
backend/build/
backend/out/


# ——————————————————————————————————————————
#  LOGS
# ——————————————————————————————————————————
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend/logs/
backend/*.log


# ——————————————————————————————————————————
#  DEPENDENCY LOCK FILES (pick ONE and keep it)
#  Uncomment the ones you are NOT using
# ——————————————————————————————————————————
# If you use npm  → commit package-lock.json, ignore yarn.lock
# If you use yarn → commit yarn.lock, ignore package-lock.json
# If you use pnpm → commit pnpm-lock.yaml, ignore others

# yarn.lock
# pnpm-lock.yaml


# ——————————————————————————————————————————
#  RUNTIME & CACHE
# ——————————————————————————————————————————
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Node.js runtime files
pids/
*.pid
*.seed
*.pid.lock

# nyc / Istanbul coverage
coverage/
frontend/coverage/
backend/coverage/
.nyc_output/


# ——————————————————————————————————————————
#  EDITOR & IDE
# ——————————————————————————————————————————

# VS Code
.vscode/
!.vscode/extensions.json    # ← keep this if you want to share recommended extensions
!.vscode/settings.json      # ← keep this if you want shared workspace settings

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# Sublime Text
*.sublime-project
*.sublime-workspace


# ——————————————————————————————————————————
#  OPERATING SYSTEM
# ——————————————————————————————————————————

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~


# ——————————————————————————————————————————
#  TESTING
# ——————————————————————————————————————————
coverage/
*.lcov
.jest-cache/
frontend/coverage/
backend/coverage/


# ——————————————————————————————————————————
#  DOCKER  (if you add it later)
# ——————————————————————————————————————————
# .dockerignore is separate, but keep these out of git too:
# docker-compose.override.yml


# ——————————————————————————————————————————
#  MISC
# ——————————————————————————————————————————

# Optional REPL history
.node_repl_history

# Yarn Plug'n'Play
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig